{
  "manifest_version": 3,
  "name": "Powder Clipper",
  "version": "1.0",
  "description": "Send web highlights directly to your local Powder Vault",
  "permissions": ["activeTab", "scripting", "clipboardRead"],
  "host_permissions": ["http://127.0.0.1:8000/*"],
  "action": {
    "default_popup": "popup.html"
  }
}