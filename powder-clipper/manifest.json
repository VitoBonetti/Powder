{
  "manifest_version": 3,
  "name": "Powder Clipper",
  "version": "1.0",
  "permissions": ["activeTab", "scripting", "clipboardRead", "storage"],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "public/logo16.png",
      "48": "public/logo48.png",
      "128": "public/logo128.png"
    }
  },
  "icons": {
    "16": "public/logo16.png",
    "48": "public/logo48.png",
    "128": "public/logo128.png"
  }
}